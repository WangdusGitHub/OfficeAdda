{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/server.js"
        }
    ],
    "env": {
        "PORT": "5000",
        "MONGODB_URI": "${MONGODB_URI}",
        "JWT_SECRET": "${JWT_SECRET}",
        "JWT_EXPIRE": "7d",
        "CLOUDINARY_CLOUD_NAME": "${CLOUDINARY_CLOUD_NAME}",
        "CLOUDINARY_API_KEY": "${CLOUDINARY_API_KEY}",
        "CLOUDINARY_API_SECRET": "${CLOUDINARY_API_SECRET}",
        "MAIL_HOST": "${MAIL_HOST}",
        "MAIL_PORT": "${MAIL_PORT}",
        "MAIL_USER": "${MAIL_USER}",
        "MAIL_PASS": "${MAIL_PASS}",
        "CLIENT_URL": "${CLIENT_URL}"
    }
}